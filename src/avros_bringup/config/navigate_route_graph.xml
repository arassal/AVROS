<!--
  Navigation BT for AVROS — ComputeRoute once, then FollowPath with recovery.
  BT.CPP v4 format for Jazzy.
  No spin/backup recovery (Ackermann vehicle cannot rotate in place).

  ComputeRoute runs ONCE (Sequence, not PipelineSequence) so the path is
  stable — Pure Pursuit can steer back to the path after overshooting turns.
  ReactiveFallback stops FollowPath when the robot reaches the original
  nav goal (handles route paths that extend past the goal to distant nodes).
-->
<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="3" name="NavigateRecovery">
      <Sequence name="NavigateSequence">
        <ComputeRoute goal="{goal}" path="{path}" route="{route}" use_poses="true" error_code_id="{compute_path_error_code}"/>
        <ReactiveFallback name="FollowUntilGoalReached">
          <GoalReached goal="{goal}" global_frame="map" robot_base_frame="base_link"/>
          <FollowPath path="{path}" controller_id="FollowPath" error_code_id="{follow_path_error_code}"/>
        </ReactiveFallback>
      </Sequence>
      <Sequence name="RecoveryActions">
        <ClearEntireCostmap name="ClearLocalCostmap" service_name="local_costmap/clear_entirely_local_costmap"/>
        <ClearEntireCostmap name="ClearGlobalCostmap" service_name="global_costmap/clear_entirely_global_costmap"/>
        <Wait wait_duration="3"/>
      </Sequence>
    </RecoveryNode>
  </BehaviorTree>
</root>

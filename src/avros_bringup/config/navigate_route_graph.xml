<!--
  Navigation BT for AVROS (Humble-compatible, BehaviorTree.CPP v3).

  Fallback planner order:
    1. ComputeRoute   — graph-based road path via nav2_route (fast, follows campus roads)
    2. ComputePathToPose — freespace Dubin path via SmacPlannerHybrid (works anywhere)

  ComputeRoute plans along the pre-built campus road graph (551 nodes, 1392 edges).
  If the robot is too far from the graph or no route exists, ComputePathToPose
  provides a freespace fallback.

  No spin recovery — Ackermann vehicle cannot rotate in place.
-->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <PipelineSequence name="NavigateWithReplanning">
      <RateController hz="0.5">
        <Fallback>
          <!-- Skip replanning if goal unchanged and current path is still valid -->
          <ReactiveSequence>
            <Inverter>
              <GlobalUpdatedGoal/>
            </Inverter>
            <IsPathValid path="{path}"/>
          </ReactiveSequence>
          <!-- Primary: road-graph path (starts at nearest graph node) -->
          <ComputeRoute goal="{goal}" path="{path}" use_poses="true"/>
          <!-- Fallback: freespace path (starts at robot, works anywhere) -->
          <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>
        </Fallback>
      </RateController>
      <FollowPath path="{path}" controller_id="FollowPath"/>
    </PipelineSequence>
  </BehaviorTree>
</root>
